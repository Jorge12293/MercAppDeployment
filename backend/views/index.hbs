<div class="container">

  <div class="page-header">
    <div>
      <h1>Dashboard</h1>
      <p>Bienvenido de vuelta, <strong>{{usuario}}</strong></p>
    </div>
    <a href="/productos/nuevo" class="btn btn-primary">+ Nuevo producto</a>
  </div>

  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon stat-icon--blue">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
        </svg>
      </div>
      <div class="stat-info">
        <p class="stat-label">Total productos</p>
        <p class="stat-value">{{totalProductos}}</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon stat-icon--green">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="stat-info">
        <p class="stat-label">Valor del inventario</p>
        <p class="stat-value">${{valorInventario}}</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon stat-icon--purple">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/>
        </svg>
      </div>
      <div class="stat-info">
        <p class="stat-label">Últimos agregados</p>
        <p class="stat-value">{{productos.length}}</p>
      </div>
    </div>
  </div>

  <!-- Tabla recientes -->
  <div class="dashboard-section">
    <div class="section-header">
      <h2>Productos recientes</h2>
      <a href="/productos" class="btn btn-outline btn-sm">Ver todos</a>
    </div>

    {{#if productos.length}}
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Imagen</th>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {{#each productos}}
          <tr>
            <td>
              {{#if imagen}}
                <img src="{{#if (startsWith imagen "http")}}{{imagen}}{{else}}/uploads/{{imagen}}{{/if}}" alt="{{nombre}}" class="img-thumb">
              {{else}}
                <span class="no-img">—</span>
              {{/if}}
            </td>
            <td><strong>{{nombre}}</strong></td>
            <td>${{precio}}</td>
            <td>
              <a href="/productos/editar/{{_id}}" class="btn btn-warning btn-sm">Editar</a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="empty-state">
      <p>Aún no hay productos. <a href="/productos/nuevo" class="btn btn-primary" style="margin-left:.5rem">Crear uno</a></p>
    </div>
    {{/if}}
  </div>

</div>
