<div class="perfil-page">

  <div class="perfil-grid">

    <!-- Card: Información -->
    <div class="form-card">
      <div class="perfil-avatar">
        <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>

      <h2 class="form-title" style="text-align:center;border:none;margin-bottom:1.25rem">
        {{usuario.nombre}}
      </h2>

      <div class="perfil-info">
        <div class="perfil-row">
          <span class="perfil-label">Nombre</span>
          <span class="perfil-value">{{usuario.nombre}}</span>
        </div>
        <div class="perfil-row">
          <span class="perfil-label">Correo</span>
          <span class="perfil-value">{{usuario.email}}</span>
        </div>
        <div class="perfil-row">
          <span class="perfil-label">Miembro desde</span>
          <span class="perfil-value">{{formatDate usuario.createdAt}}</span>
        </div>
      </div>
    </div>

    <!-- Card: Cambiar contraseña -->
    <div class="form-card">
      <h2 class="form-title">Cambiar contraseña</h2>

      {{#if passOk}}
        <div class="alert-ok">Contraseña actualizada correctamente.</div>
      {{/if}}
      {{#if passError}}
        <div class="alert-errores" style="list-style:none;padding:.85rem 1rem">{{passError}}</div>
      {{/if}}

      <form action="/perfil/password" method="POST">

        <div class="form-group">
          <label>Contraseña actual</label>
          <div class="input-password">
            <input type="password" name="actual" placeholder="Tu contraseña actual">
            <button type="button" class="toggle-password" aria-label="Mostrar contraseña">
              <svg class="icon-eye" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <svg class="icon-eye-off" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label>Nueva contraseña</label>
          <div class="input-password">
            <input type="password" name="nueva" placeholder="Mínimo 6 caracteres">
            <button type="button" class="toggle-password" aria-label="Mostrar contraseña">
              <svg class="icon-eye" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <svg class="icon-eye-off" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
              </svg>
            </button>
          </div>
          <p class="form-hint">Mínimo 6 caracteres.</p>
        </div>

        <div class="form-group">
          <label>Confirmar nueva contraseña</label>
          <div class="input-password">
            <input type="password" name="confirmar" placeholder="Repite la nueva contraseña">
            <button type="button" class="toggle-password" aria-label="Mostrar contraseña">
              <svg class="icon-eye" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <svg class="icon-eye-off" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Actualizar contraseña</button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  document.querySelectorAll('.toggle-password').forEach(btn => {
    btn.addEventListener('click', () => {
      const input  = btn.closest('.input-password').querySelector('input');
      const eyeOn  = btn.querySelector('.icon-eye');
      const eyeOff = btn.querySelector('.icon-eye-off');
      const vis    = input.type === 'text';
      input.type        = vis ? 'password' : 'text';
      eyeOn.style.display  = vis ? '' : 'none';
      eyeOff.style.display = vis ? 'none' : '';
    });
  });
</script>
