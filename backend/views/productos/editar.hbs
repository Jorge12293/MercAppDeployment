<div class="container">

  <div class="page-header">
    <div>
      <h1>Editar producto</h1>
      <p>Modifica los campos que necesites</p>
    </div>
    <a href="/productos" class="btn btn-outline">← Volver</a>
  </div>

  <div class="form-card">
    <h2 class="form-title">{{producto.nombre}}</h2>

    {{> errores}}

    <form action="/productos/actualizar/{{producto._id}}" method="POST" enctype="multipart/form-data">

      <div class="form-group">
        <label>Nombre *</label>
        <input type="text" name="nombre" value="{{producto.nombre}}"
               placeholder="Ej: Camiseta azul talla M">
      </div>

      <div class="form-group">
        <label>Descripción</label>
        <textarea name="descripcion" placeholder="Describe el producto...">{{producto.descripcion}}</textarea>
        <p class="form-hint">Máximo 500 caracteres.</p>
      </div>

      <div class="form-group">
        <label>Precio *</label>
        <input type="number" name="precio" value="{{producto.precio}}"
               min="0" step="0.01" placeholder="0.00">
      </div>

      <div class="form-group">
        <label>Imagen del producto</label>
        {{#if producto.imagen}}
          <img id="previewImg" class="img-preview"
               src="/uploads/{{producto.imagen}}" alt="{{producto.nombre}}">
        {{else}}
          <img id="previewImg" class="img-preview" src="" alt="" style="display:none">
        {{/if}}
        <input type="file" name="imagen" accept=".jpg,.jpeg,.png,.webp" id="inputImagen">
        <p class="form-hint">Deja vacío para conservar la imagen actual. JPG, PNG o WEBP — máximo 2 MB.</p>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Actualizar producto</button>
        <a href="/productos" class="btn btn-outline">Cancelar</a>
      </div>

    </form>
  </div>
</div>

<script>
  document.getElementById('inputImagen').addEventListener('change', function () {
    const preview = document.getElementById('previewImg');
    const file = this.files[0];
    if (file) {
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
    }
  });
</script>
