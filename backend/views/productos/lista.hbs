<div class="container">

  <div class="page-header">
    <div>
      <h1>Productos</h1>
      <p>Gestiona el inventario de tu tienda</p>
    </div>
    <a href="/productos/nuevo" class="btn btn-primary">+ Nuevo producto</a>
  </div>

  {{#if productos.length}}
  <div class="dashboard-section">
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th style="width:72px">Imagen</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th style="width:140px">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {{#each productos}}
          <tr>
            <td>
              {{#if imagen}}
                <img src="{{#if (startsWith imagen "http")}}{{imagen}}{{else}}/uploads/{{imagen}}{{/if}}" alt="{{nombre}}" class="img-thumb">
              {{else}}
                <div class="img-thumb-placeholder">
                  <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                  </svg>
                </div>
              {{/if}}
            </td>
            <td><strong>{{nombre}}</strong></td>
            <td class="td-desc">{{descripcion}}</td>
            <td><span class="price-tag">${{precio}}</span></td>
            <td>
              <div class="acciones">
                <a href="/productos/editar/{{_id}}" class="btn btn-warning btn-sm">Editar</a>
                <form action="/productos/eliminar/{{_id}}" method="POST"
                      onsubmit="return confirm('¿Eliminar «{{nombre}}»?')">
                  <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                </form>
              </div>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{else}}
  <div class="empty-state">
    <svg width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round"
        d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
    </svg>
    <p>No hay productos registrados.</p>
    <a href="/productos/nuevo" class="btn btn-primary" style="margin-top:1rem">Agregar el primero</a>
  </div>
  {{/if}}

</div>
