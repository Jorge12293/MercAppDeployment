<div class="container">

  <div class="page-header">
    <div>
      <h1>Nuevo producto</h1>
      <p>Completa los datos para agregar un producto al inventario</p>
    </div>
    <a href="/productos" class="btn btn-outline">← Volver</a>
  </div>

  <div class="form-card">
    <h2 class="form-title">Información del producto</h2>

    {{> errores}}

    <form action="/productos" method="POST" enctype="multipart/form-data">

      <div class="form-group">
        <label>Nombre *</label>
        <input type="text" name="nombre" value="{{body.nombre}}"
               placeholder="Ej: Camiseta azul talla M">
      </div>

      <div class="form-group">
        <label>Descripción</label>
        <textarea name="descripcion" placeholder="Describe el producto...">{{body.descripcion}}</textarea>
        <p class="form-hint">Máximo 500 caracteres.</p>
      </div>

      <div class="form-group">
        <label>Precio *</label>
        <input type="number" name="precio" value="{{body.precio}}"
               min="0" step="0.01" placeholder="0.00">
      </div>

      <div class="form-group">
        <label>Imagen del producto</label>
        <input type="file" name="imagen" accept=".jpg,.jpeg,.png,.webp" id="inputImagen">
        <p class="form-hint">JPG, PNG o WEBP — máximo 2 MB.</p>
        <img id="previewImg" class="img-preview" src="" alt="" style="display:none; margin-top:.5rem">
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Guardar producto</button>
        <a href="/productos" class="btn btn-outline">Cancelar</a>
      </div>

    </form>
  </div>
</div>

<script>
  document.getElementById('inputImagen').addEventListener('change', function () {
    const preview = document.getElementById('previewImg');
    const file = this.files[0];
    if (file) {
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
    } else {
      preview.style.display = 'none';
    }
  });
</script>
